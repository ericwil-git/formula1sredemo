@page "/race/{Year:int}/{Round:int}"
@namespace F1.Web.Pages
@inject FileGeneratorClient FileGen
@inject IJSRuntime JS
@implements IAsyncDisposable

<h1>Race results — @Year round @Round</h1>

@if (table is null)
{
    <p><em>Loading…</em></p>
}
else if (table.Rows.Count == 0)
{
    <p>No race data available. The database may be empty.</p>
}
else
{
    <p>
        <strong>@table.Rows.Count</strong> total lap-rows across <strong>@drivers.Count</strong> drivers.
        &nbsp;
        <label>
            Driver:
            <select @bind="driverFilter" @bind:after="OnFilterChanged">
                <option value="">All drivers</option>
                @foreach (var d in drivers)
                {
                    <option value="@d">@d</option>
                }
            </select>
        </label>
    </p>

    <h2>Position by lap</h2>
    <canvas id="positionChart" height="120"></canvas>

    <h2>Lap-by-lap data</h2>
    var visible = FilteredRows().ToList();
    <p><em>showing @visible.Count rows@(visible.Count > 200 ? " (capped at 200)" : "")</em></p>
    <table>
        <thead><tr>@foreach (var h in table.Headers) { <th>@h</th> }</tr></thead>
        <tbody>
            @foreach (var row in visible.Take(200))
            {
                <tr>@foreach (var c in row) { <td>@c</td> }</tr>
            }
        </tbody>
    </table>
}

@code {
    [Parameter] public int Year { get; set; }
    [Parameter] public int Round { get; set; }

    private CsvTable.Table? table;
    private List<string> drivers = new();
    private string driverFilter = "";
    private bool _chartDirty;

    protected override async Task OnParametersSetAsync()
    {
        var raw = await FileGen.GetRaceCsvAsync(Year, Round);
        table = CsvTable.Parse(raw);
        var driverIdx = CsvTable.IndexOf(table.Headers, "Driver");
        drivers = driverIdx < 0
            ? new List<string>()
            : table.Rows.Select(r => r[driverIdx]).Distinct().OrderBy(s => s).ToList();
        driverFilter = "";
        _chartDirty = true;
    }

    private IEnumerable<IReadOnlyList<string>> FilteredRows()
    {
        if (table is null) return Array.Empty<IReadOnlyList<string>>();
        if (string.IsNullOrEmpty(driverFilter)) return table.Rows;
        var idx = CsvTable.IndexOf(table.Headers, "Driver");
        if (idx < 0) return table.Rows;
        return table.Rows.Where(r => string.Equals(r[idx], driverFilter, StringComparison.OrdinalIgnoreCase));
    }

    private void OnFilterChanged() => _chartDirty = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (table is null || table.Rows.Count == 0 || !_chartDirty) return;

        var driverIdx = CsvTable.IndexOf(table.Headers, "Driver");
        var lapIdx    = CsvTable.IndexOf(table.Headers, "LapNumber");
        var posIdx    = CsvTable.IndexOf(table.Headers, "Position");
        if (driverIdx < 0 || lapIdx < 0 || posIdx < 0) return;

        var rows = FilteredRows();
        var byDriver = rows.GroupBy(r => r[driverIdx]);
        var palette = new[] {
            "#f78166","#58a6ff","#3fb950","#d29922","#a371f7",
            "#ff7b72","#79c0ff","#56d364","#e3b341","#bc8cff"
        };
        var idx = 0;
        var datasets = new List<object>();
        foreach (var g in byDriver)
        {
            var pts = g.Where(r => int.TryParse(r[lapIdx], out _) && int.TryParse(r[posIdx], out _))
                       .Select(r => new { x = int.Parse(r[lapIdx]), y = int.Parse(r[posIdx]) })
                       .OrderBy(p => p.x).ToArray();
            if (pts.Length == 0) continue;
            datasets.Add(new {
                label = g.Key,
                points = pts,
                color = palette[idx++ % palette.Length]
            });
        }

        var title = string.IsNullOrEmpty(driverFilter)
            ? $"{Year} round {Round}"
            : $"{Year} round {Round} — {driverFilter}";
        await JS.InvokeVoidAsync("f1Charts.renderLineChart",
            "positionChart", title, datasets, "Lap");
        _chartDirty = false;
    }

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("f1Charts.destroy", "positionChart"); }
        catch { /* circuit may be disposed */ }
    }
}
