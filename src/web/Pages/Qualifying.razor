@page "/qualifying/{Year:int}/{Round:int}"
@namespace F1.Web.Pages
@inject FileGeneratorClient FileGen

<h1>Qualifying — @Year round @Round</h1>

@if (csv is null)
{
    <p>Loading…</p>
}
else
{
    <pre>@csv</pre>
    <!-- TODO(spec §7): render Q1/Q2/Q3 grid + delta-to-pole bar chart. -->
}

@code {
    [Parameter] public int Year { get; set; }
    [Parameter] public int Round { get; set; }

    private string? csv;

    protected override async Task OnParametersSetAsync()
    {
        csv = await FileGen.GetQualifyingCsvAsync(Year, Round);
    }
}
